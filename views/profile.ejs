<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Profile</title>
    <link rel="stylesheet" href="/stylesheets/global.css">
</head>
<body>
    <div class="w-full min-h-screen bg-zinc-900 text-white p-10">
        <%
        const greetings = ["Hey there", "Welcome back", "Good to see you", "What's up", "Howdy", "Yo", "Hello there", "Nice to see you", "Look who's back", "Let's get started", "Ready to create something?", "Time to shine", "Make today count", "Look who showed up", "The legend has arrived", "Oh look who it is", "Back again", "You're back!", "Finally you showed up","The wait is over"];
        const greeting = greetings[Math.floor(Math.random() * greetings.length)];
        %>
        
        <!-- navbar -->
        <div class="flex items-center justify-between mb-10">
            <h1 class="text-2xl font-bold">PostApp</h1>
            <a href="/logout" class="px-4 py-2 rounded-lg bg-red-500 hover:bg-red-600 transition text-sm font-semibold">
                Logout
            </a>
        </div>

        <!-- profile info -->
        <div class="bg-zinc-800 p-6 rounded-2xl mb-8 flex items-center gap-5">
            <div class="w-16 h-16 rounded-full bg-blue-500 flex items-center justify-center text-2xl font-bold">
                <%= user.email[0].toUpperCase() %>
            </div>
            <div>
                <h2 class="text-xl font-bold"><%= greeting %>, <%= user.name %></h2>
                <p class="text-blue-400 text-sm font-semibold">@<%= user.username %></p>
                <p class="text-zinc-400 text-sm"><%= user.email %></p>
            </div>
        </div>

        <!-- create post -->
        <div class="bg-zinc-800 p-6 rounded-2xl mb-8 w-full sm:w-1/2 lg:w-1/3">
            <h3 class="text-lg font-semibold mb-4">Create a Post</h3>
            <form action="/post" method="post" class="flex flex-col gap-3">
                <textarea class="px-3 py-2 rounded-lg bg-zinc-700 border border-zinc-600 outline-none focus:border-blue-500 transition resize-none" rows="3" placeholder="What's on your mind?" name="content"></textarea>

                <input 
                    class="px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-600 cursor-pointer transition font-semibold" 
                    type="submit" 
                    value="Post"
                >
            </form>
        </div>

        <!-- posts feed -->
        <h3 class="text-lg font-semibold mb-3">Your Posts</h3>

        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 w-full">
            
            <% if(posts && posts.length > 0) { %>
                <% posts.reverse().forEach(post => { %>
                    <div class="bg-zinc-800 p-3 rounded-2xl border border-zinc-700">
                        <div class="flex items-center justify-between mb-2 w-full">
                            <p class="text-blue-400 text-sm font-semibold">
                                @<%= user.username %>
                            </p>
                            <p class="text-zinc-500 text-xs">
                                <%= new Date(post.date).toLocaleString("en-IN", { dateStyle: "medium", timeStyle: "short", hour12: false }) %>
                            </p>
                        </div>                        
                        <div id="content-<%= post._id %>">
                            <p class="text-zinc-300 whitespace-pre-wrap wrap-break-word"><%= post.content %></p>
                        </div>

                        <div class="flex justify-between mt-3 text-sm">
                        <span class="text-blue-400 cursor-pointer">Like</span>

                        <span class="text-zinc-400 cursor-pointer" onclick="enableEdit('<%= post._id %>')">edit</span>
                    </div>
                </div>
            <% }) %>
            <% } else { %>
                <div class="bg-zinc-800 p-5 rounded-2xl text-zinc-400 text-center col-span-full">
                    No posts yet. Create your first post!
                </div>
            <% } %>

        </div>      
    </div>
    <script>
    function enableEdit(id) {
        const el = document.getElementById(`content-${id}`);
        const currentText = el.innerText;

        el.innerHTML = `
            <textarea id="edit-${id}" class="w-full bg-zinc-700 p-2 rounded">${currentText}</textarea>
            <div class="mt-2 flex gap-2">
                <button type="button" onclick="saveEdit('${id}')" class="px-3 py-1 bg-blue-500 rounded">Save</button>
                <button type="button" onclick="location.reload()" class="px-3 py-1 bg-zinc-600 rounded">Cancel</button>
            </div>
        `;
    }

    async function saveEdit(id) {
        const content = document.getElementById(`edit-${id}`).value;

        await fetch(`/post/edit/${id}`, {
            method: "POST",
            headers: {
                "Content-Type": "application/json"
            },
            body: JSON.stringify({ content })
        });

        location.reload();
    }
    </script>
</body>
</html>