<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <link rel="stylesheet" href="/stylesheets/global.css">
</head>
<body>
    <div class="w-full h-screen bg-zinc-900 text-white flex items-center justify-center">
        <div class="bg-zinc-800 p-10 rounded-2xl shadow-2xl w-96">

            <h3 class="text-3xl font-bold mb-2">Welcome Back</h3>
            <p class="text-zinc-400 text-sm mb-8">Login to your account</p>

            <% if (error) { %>
                <p class="text-red-400 text-sm mb-4"><%= error %></p>
            <% } %>

            <form action="/login" method="post" class="flex flex-col gap-4">
                <div class="flex flex-col gap-1">
                    <label class="text-sm text-zinc-400">Email or Username</label>
                    <input class="px-3 py-2 rounded-lg bg-zinc-700 border border-zinc-600 outline-none focus:border-blue-500 transition" type="text" placeholder="Enter email or username" name="identifier" value="<%= identifier || '' %>">
                </div>

                <div class="flex flex-col gap-1">
                    <label class="text-sm text-zinc-400">Password</label>
                    <input class="px-3 py-2 rounded-lg bg-zinc-700 border border-zinc-600 outline-none focus:border-blue-500 transition" type="password" placeholder="Enter password" name="password">
                </div>

                <input class="px-4 py-2 rounded-lg bg-blue-500 hover:bg-blue-600 cursor-pointer transition font-semibold mt-2" type="submit" value="Login">
            </form>

            <p class="text-zinc-400 text-sm text-center mt-6">Don't have an account?
                <a class="text-blue-500 hover:underline" href="/register">Create Account</a>
            </p>

        </div>
    </div>
</body>
</html>